{
  "uid": "shop-service",
  "title": "Shop Service Overview",
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["shop-service", "prometheus"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Requests /s",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"shop-service\",uri!~\".*actuator.*\"}[$__rate_interval]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Error rate /s (5xx)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"shop-service\",status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx rps",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.1 } ] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "HTTP p95 latency (ms)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"shop-service\",uri!~\".*actuator.*\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "fieldConfig": { "defaults": { "unit": "ms", "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 500 }, { "color": "red", "value": 1000 } ] } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Heap usage",
      "id": 4,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (application) (jvm_memory_used_bytes{application=\"shop-service\",area=\"heap\"})", "legendFormat": "heap used", "refId": "A" },
        { "expr": "sum by (application) (jvm_memory_max_bytes{application=\"shop-service\",area=\"heap\"})", "legendFormat": "heap max", "refId": "B" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU usage (process)",
      "id": 5,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_cpu_usage{application=\"shop-service\"}", "legendFormat": "process", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "mappings": [],
          "thresholds": { "mode": "percentage", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.8 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "DB connections (HikariCP)",
      "id": 6,
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max_over_time(hikaricp_connections_active{application=\"shop-service\"}[$__rate_interval])", "legendFormat": "active", "refId": "A" },
        { "expr": "avg_over_time(hikaricp_connections_idle{application=\"shop-service\"}[$__rate_interval])", "legendFormat": "idle avg", "refId": "B" },
        { "expr": "max_over_time(hikaricp_connections_pending{application=\"shop-service\"}[$__rate_interval])", "legendFormat": "pending", "refId": "C" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "GC pause (s)",
      "id": 7,
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{application=\"shop-service\"}[$__rate_interval])", "legendFormat": "pause rate", "refId": "A" }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": { "defaults": { "unit": "s", "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 } ] } }, "overrides": [] }
    }
  ]
}
